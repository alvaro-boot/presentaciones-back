PORT=3001
NODE_ENV=development

# MySQL (local o Hostinger remoto)
DATABASE_HOST=srv883.hstgr.io
DATABASE_PORT=3306
DATABASE_USER=u260978850_sites
DATABASE_PASSWORD=tu_contraseña
DATABASE_NAME=u260978850_sites

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Supabase Storage vía API (alternativa al protocolo S3)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=archivos

# Supabase Storage vía S3 (recomendado para subidas)
# Dashboard → Storage → S3 → copiar endpoint, región y claves
SUPABASE_S3_ENDPOINT=https://TU_PROYECTO.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-2
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# Duración de cada URL firmada (segundos); se renueva al mostrar la diapositiva
SIGNED_URL_EXPIRES_SECONDS=3600

CORS_ORIGIN=http://localhost:3000

ADMIN_EMAIL=admin@cootravir.com
